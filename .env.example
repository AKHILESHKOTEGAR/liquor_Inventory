# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/liquor_inventory?schema=public"

# API Server
PORT=3001
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="8h"
BCRYPT_ROUNDS=10

# Web App
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# File Storage (for cap photos)
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=5
