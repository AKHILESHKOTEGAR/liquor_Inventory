# Database — Railway provides this automatically when you add a PostgreSQL service
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=8h

# Server
NODE_ENV=production
PORT=3001

# Security
BCRYPT_ROUNDS=12

# CORS — comma-separated list of allowed origins (your Vercel URL + any custom domain)
# Leave blank to allow all origins (development only)
CORS_ORIGIN=https://your-app.vercel.app,https://yourdomain.com

# File uploads
UPLOAD_DIR=/tmp/uploads
MAX_FILE_SIZE_MB=5
